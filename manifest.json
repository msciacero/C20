{
  "manifest_version": 3,
  "name": "C20",
  "version": "0.0.0.1",
  "description": "Adds additional UI features to 5e Roll20 games.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://app.roll20.net/editor"],
      "js": [
        "components/compendium/compendium.js",
        "components/compendium/compendiumEditor.js",
        "components/compendium/editors/classEditor.js",
        "components/compendium/editors/conditionsEditor.js",
        "components/compendium/editors/traitEditor.js",
        "components/compendium/editors/itemEditor.js",
        "components/compendium/editors/spellEditor.js",
        "components/journal/journal.js",
        "components/settings/appSettings.js",
        "components/settings/savedData.js",
        "components/shared/formFields.js",
        "components/shared/markdown.js",
        "components/shared/modal.js",
        "components/shared/storage.js",
        "components/shared/tab.js",
        "components/shared/utilities.js",
        "library/external/sortable.js",
        "library/external/idb.js",
        "library/external/pluralize.js",
        "library/external/uFuzzy.js",
        "mainApp.js"
      ],
      "css": [
        "library/styles/app/compendium.css",
        "library/styles/app/compendiumEditor.css",
        "library/styles/app/journal.css",
        "library/styles/app/settings.css",
        "library/styles/shared/formFields.css",
        "library/styles/shared/layout.css",
        "library/styles/shared/modal.css",
        "library/styles/shared/tab.css"
      ],
      "world": "ISOLATED"
    },
    {
      "matches": ["https://app.roll20.net/editor/character/*"],
      "js": [
        "components/compendium/editors/itemEditor.js",
        "components/compendium/compendiumImport.js",
        "components/settings/sheetSettings.js",
        "components/shared/formFields.js",
        "components/shared/markdown.js",
        "components/shared/modal.js",
        "components/shared/storage.js",
        "components/shared/tab.js",
        "components/shared/utilities.js",
        "components/sheet/attacks.js",
        "components/sheet/conditions.js",
        "components/sheet/defenses.js",
        "components/sheet/inventory.js",
        "components/sheet/miniNotes.js",
        "components/sheet/spells.js",
        "components/sheet/traits.js",
        "library/external/sortable.js",
        "library/external/idb.js",
        "library/external/expr-eval.js",
        "mainSheet.js"
      ],
      "css": [
        "library/styles/shared/formFields.css",
        "library/styles/shared/layout.css",
        "library/styles/shared/modal.css",
        "library/styles/shared/tab.css",
        "library/styles/sheet/conditions.css",
        "library/styles/sheet/defense.css",
        "library/styles/sheet/inventory.css",
        "library/styles/sheet/miniNote.css",
        "library/styles/sheet/settings.css",
        "library/styles/sheet/spells.css",
        "library/styles/sheet/traits.css"
      ],
      "all_frames": true,
      "world": "ISOLATED"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "/library/data/campaignInfo.js",
        "library/data/dnd2014/conditions.json",
        "library/icons/resistance.svg",
        "library/icons/filter-solid-full.svg"
      ],
      "matches": ["https://app.roll20.net/*"]
    }
  ]
}
